# Configuracion de produccion para el App Server en AWS.
# Este archivo es una guia local: el archivo real vive en /opt/forge-core/backend/.env dentro de la EC2.

NODE_ENV=production
PORT=4000
FRONTEND_ORIGIN=http://52.73.100.42
USE_MOCK_DATA=false

# Usar la IP privada del servidor de base de datos, no la IP publica.
DB_HOST=172.31.29.30
DB_PORT=3306
DB_USER=forge_app
DB_PASSWORD=CAMBIAR_EN_EL_SERVIDOR
DB_NAME=forge_core

# Comunidad/reseñas en MongoDB Atlas Free M0.
# En Atlas agrega la IP publica del App Server al Network Access.
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=forge_core

METRICS_INTERVAL_SECONDS=30
